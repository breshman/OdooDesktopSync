<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.desktop</groupId>
  <artifactId>desktop</artifactId>
  <packaging>jar</packaging>
  <version>1.0-SNAPSHOT</version>
  <name>desktop</name>
  <url>http://maven.apache.org</url>
  <properties>
    <maven.compiler.source>21</maven.compiler.source>
    <maven.compiler.target>21</maven.compiler.target>
  </properties>

  <dependencies>
    <dependency>
      <groupId>junit</groupId>
      <artifactId>junit</artifactId>
      <version>3.8.1</version>
      <scope>test</scope>
    </dependency>
    <!-- JCEF Maven Wrapper for embedding Chromium -->
    <dependency>
      <groupId>me.friwi</groupId>
      <artifactId>jcefmaven</artifactId>
      <version>146.0.10</version>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.1.0</version>
        <configuration>
          <executable>java</executable>
          <arguments>
            <argument>--add-exports=java.desktop/sun.awt=ALL-UNNAMED</argument>
            <argument>--add-exports=java.desktop/sun.lwawt=ALL-UNNAMED</argument>
            <argument>--add-exports=java.desktop/sun.lwawt.macosx=ALL-UNNAMED</argument>
            <argument>--add-opens=java.desktop/sun.awt=ALL-UNNAMED</argument>
            <argument>--add-opens=java.desktop/sun.lwawt=ALL-UNNAMED</argument>
            <argument>--add-opens=java.desktop/sun.lwawt.macosx=ALL-UNNAMED</argument>
            <argument>--add-opens=java.desktop/java.awt=ALL-UNNAMED</argument>
            <argument>-classpath</argument>
            <!-- Automatically creates the classpath using all project dependencies,
                 also adding the project build directory -->
            <classpath/>
            <argument>com.desktop.App</argument>
          </arguments>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
